# ====================================================================
#  Logiztik Shipment Viewer - configuratie
#  Kopieer dit bestand naar  .env  en vul je eigen gegevens in.
#  Het echte .env-bestand wordt door .gitignore buiten Git gehouden.
# ====================================================================

# Jouw klantcode bij Logiztik Alliance.
CUSTOMER_CODE=CLI0000000

# Jouw Api-Key (AuthenticationToken) voor de productie-omgeving.
API_KEY=YOUR_API_KEY_HERE

# Headernaam waarmee de Api-Key wordt meegestuurd.
# LET OP: de Logiztik-documentatie vermeldt niet exact welke headernaam
# verwacht wordt. 'Api-Key' is de standaardgok. Werkt dat niet, probeer dan
# een alternatief, bijvoorbeeld: Authorization  /  X-Api-Key  /  ApiKey
API_KEY_HEADER=Api-Key

# Poort waarop de lokale viewer draait (open daarna http://localhost:PORT).
# Alleen van belang voor lokale server.js development.
PORT=3000

# Zet ALLEEN op 'true' als de eerste live-test faalt met een TLS-/certificaatfout.
# Dit schakelt certificaatverificatie uit - minder veilig, dus bewust gebruiken.
ALLOW_INSECURE_TLS=false

# (Vercel deployment) Rest API URL en token voor Vercel KV (Redis)
# Deze worden automatisch ingevuld door Vercel als je KV ingesteld hebt.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# FlightAware AeroAPI key — gebruikt door /api/track om per vlucht echte
# DEP/ARR tijden + delay status op te halen (vervangt scheduled-based heuristiek).
# Verkrijgbaar via https://flightaware.com/aeroapi
FA_API_KEY=YOUR_AEROAPI_KEY_HERE

# TrackingMore v4 API key — multi-carrier AWB tracking fallback.
# Voor alle prefixes zonder dedicated scraper (KLM 074, Emirates 176, Ethiopian
# 071, Lufthansa 020, ...). Update-cyclus 4-6 uur. Free tier = beperkt aantal
# trackings/maand; frontend cachet 24h en fetcht alleen op user-actie.
# Verkrijgbaar via https://www.trackingmore.com
TRACKINGMORE_API_KEY=YOUR_TRACKINGMORE_KEY_HERE
